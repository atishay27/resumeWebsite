# Copy this file to .env and fill in your key for local development.
# Get a free access key at https://web3forms.com (it is a public client-side key).
PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key

# Optional: hCaptcha site key (public). hCaptcha is free on Web3Forms and the form
# already defaults to Web3Forms' shared zero-config key, so you usually leave this
# blank. Only set it if you registered your own hCaptcha account (then also add its
# SECRET key in the Web3Forms dashboard → form settings → spam protection).
PUBLIC_HCAPTCHA_SITE_KEY=
