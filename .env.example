# Copy this file to .env for local development.
#
# PUBLIC_ vars are inlined into the client bundle at BUILD time (safe to expose).
# Server-only SECRETS live in .dev.vars (see .dev.vars.example) for local dev, and
# in the Cloudflare Worker's encrypted variables in production.

# Cloudflare Turnstile site key (public). Create a widget at:
# Cloudflare dashboard → Turnstile. The matching SECRET goes in .dev.vars.
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
