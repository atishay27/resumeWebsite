---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <main class="min-h-screen flex items-center justify-center relative" style="padding:100px clamp(20px,5vw,60px);">
    <div class="text-center">
      <div class="grad-text font-sora font-extrabold" style="font-size:clamp(4.5rem,20vw,10rem);line-height:1;">404</div>
      <h1 class="font-sora font-bold" style="font-size:clamp(1.5rem,4vw,2.2rem);margin:6px 0 14px;">Page not found</h1>
      <p class="text-dim" style="max-width:460px;margin:0 auto 30px;font-size:1.02rem;">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <a href="/" class="btn btn-primary">← Back to home</a>
    </div>
  </main>
</Layout>
