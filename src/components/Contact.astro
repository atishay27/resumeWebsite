---
import resume from '../data/resume.json';
import Icon from './Icon.astro';
const { contact } = resume;

// Web3Forms access key is injected at build time from the PUBLIC_WEB3FORMS_KEY
// environment variable (set it in Cloudflare Pages → Settings → Environment variables,
// or in a local .env file). It is a public client-side key by design.
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
const blocked = contact.blockedEmailDomains.join(',');

// hCaptcha site key (public). hCaptcha is free on the Web3Forms plan; the default
// below is Web3Forms' shared zero-config site key. Override via PUBLIC_HCAPTCHA_SITE_KEY
// only if you register your own hCaptcha account and add its secret in the Web3Forms
// dashboard. The widget blocks bots/abuse of the public access key.
const hcaptchaKey = import.meta.env.PUBLIC_HCAPTCHA_SITE_KEY || '50b2fe65-b00b-4b9e-ad62-3ba471098be2';
---
<section id="contact" class="section-pad relative">
  <div class="wrap">
    <div class="eyebrow reveal">05 — Get the Resume</div>
    <h2 class="section-title reveal">{contact.heading}</h2>
    <div class="grid gap-[50px] items-start contact-grid">
      <div class="contact-info">
        <p class="reveal text-dim mb-7">{contact.intro}</p>
        {contact.features.map((f, i) => (
          <div class={`reveal ${i ? 'd' + i : ''} flex gap-3.5 mb-5 items-start`}>
            <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center shrink-0 text-accent" style="background:var(--accent-soft);">
              <Icon name={f.icon} />
            </div>
            <div>
              <h5 class="text-[0.98rem] mb-0.5">{f.title}</h5>
              <p class="text-[0.86rem] text-dim m-0">{f.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal d1 card rounded-[18px] p-[34px]">
        <div id="formMsg" role="status" aria-live="polite" class="hidden mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem]"></div>
        <form id="resumeForm" data-key={web3Key} data-blocked={blocked} data-subject={contact.subject} data-success={contact.successMessage} data-captcha={hcaptchaKey} novalidate>
          <div class="grid gap-4 form-row">
            <div class="field">
              <label for="cf-name">Your Name <span class="text-accent">*</span></label>
              <input id="cf-name" type="text" name="name" placeholder="Jane Doe" required />
              <div class="err">Please enter your name.</div>
            </div>
            <div class="field">
              <label for="cf-company">Company <span class="text-accent">*</span></label>
              <input id="cf-company" type="text" name="company" placeholder="Acme Inc." required />
              <div class="err">Please enter your company.</div>
            </div>
          </div>
          <div class="field">
            <label for="cf-email">Company Email <span class="text-accent">*</span></label>
            <input id="cf-email" type="email" name="email" placeholder="you@company.com" required />
            <div class="err">Please use a valid company email (no gmail/yahoo/outlook).</div>
          </div>
          <div class="grid gap-4 form-row">
            <div class="field">
              <label for="cf-role">Role / Position <span class="text-accent">*</span></label>
              <input id="cf-role" type="text" name="role" placeholder="Senior Backend Engineer" required />
              <div class="err">Please enter the role.</div>
            </div>
            <div class="field">
              <label for="cf-work-type">Work Type</label>
              <select id="cf-work-type" name="work_type">
                <option>On-site</option><option>Hybrid</option><option>Remote</option><option>Contract</option>
              </select>
            </div>
          </div>
          <div class="field">
            <label for="cf-message">Job Description / Message <span class="text-accent">*</span></label>
            <textarea id="cf-message" name="message" placeholder="Paste the JD or describe the opportunity..." required></textarea>
            <div class="err">Please add a short message or JD.</div>
          </div>
          <!-- Honeypot anti-spam -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
          {hcaptchaKey && (
            <div class="h-captcha mb-4" data-sitekey={hcaptchaKey} data-theme="dark"></div>
          )}
          <button type="submit" class="btn btn-primary w-full justify-center mt-1.5" id="submitBtn">
            <span class="btn-label">Send Request</span><Icon name="send" class="w-4 h-4" />
          </button>
          <p class="text-[0.78rem] text-dim text-center mt-3.5">🔒 Your details are sent securely and never shared.</p>
        </form>
      </div>
    </div>
  </div>
</section>

{hcaptchaKey && (
  <script is:inline src="https://js.hcaptcha.com/1/api.js" async defer></script>
)}

<style>
  .contact-grid { grid-template-columns: .85fr 1.15fr; }
  .form-row { grid-template-columns: 1fr 1fr; }
  .field { margin-bottom: 18px; }
  .field label { display: block; font-size: .82rem; color: var(--text-dim); margin-bottom: 7px; font-weight: 500; }
  .field input, .field select, .field textarea {
    width: 100%; padding: 13px 15px; border-radius: 11px;
    background: rgba(10, 22, 40, 0.5); border: 1px solid var(--card-border);
    color: var(--text); font-family: inherit; font-size: .92rem; transition: .25s;
  }
  .field textarea { resize: vertical; min-height: 110px; }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft); background: rgba(10, 22, 40, 0.8);
  }
  .field input::placeholder, .field textarea::placeholder { color: #64748b; }
  .field select {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' fill='none' stroke='%2394a3b8' stroke-width='2'><path d='M2 4l5 5 5-5'/></svg>");
    background-repeat: no-repeat; background-position: right 15px center;
  }
  .field .err { color: #f87171; font-size: .76rem; margin-top: 5px; display: none; }
  .field.invalid .err { display: block; }
  .field.invalid input, .field.invalid select, .field.invalid textarea { border-color: #f87171; }
  #formMsg.success { display: block; background: rgba(52,211,153,0.12); border: 1px solid rgba(52,211,153,0.3); color: #6ee7b7; }
  #formMsg.error { display: block; background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.3); color: #fca5a5; }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 34px; } }
  @media (max-width: 520px) { .form-row { grid-template-columns: 1fr; } }
</style>

<script>
  const form = document.getElementById('resumeForm') as HTMLFormElement | null;
  if (form) {
    const msg = document.getElementById('formMsg')!;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const label = submitBtn.querySelector('.btn-label')!;
    const KEY = form.dataset.key || '';
    const BLOCKED = (form.dataset.blocked || '').split(',').filter(Boolean);
    const SUBJECT = form.dataset.subject || 'New resume request';
    const SUCCESS = form.dataset.success || "✓ Thanks! Your request was sent. I'll reply within 24 hours.";
    const CAPTCHA = form.dataset.captcha || '';

    const setErr = (el: Element, on: boolean) => el.closest('.field')!.classList.toggle('invalid', on);
    const validEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

    form.querySelectorAll('input,textarea').forEach((f) =>
      f.addEventListener('input', () => setErr(f, false))
    );

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let ok = true;
      form.querySelectorAll<HTMLInputElement>('[required]').forEach((f) => {
        const bad = !f.value.trim();
        setErr(f, bad);
        if (bad) ok = false;
      });
      const email = form.elements.namedItem('email') as HTMLInputElement;
      if (email.value.trim()) {
        const dom = (email.value.split('@')[1] || '').toLowerCase();
        const bad = !validEmail(email.value) || BLOCKED.includes(dom);
        setErr(email, bad);
        if (bad) ok = false;
      }
      if (!ok) return;

      // Require an hCaptcha token when the widget is enabled.
      if (CAPTCHA) {
        const token = (form.querySelector('[name="h-captcha-response"]') as HTMLTextAreaElement | null)?.value;
        if (!token) {
          msg.className = 'mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem] error';
          msg.textContent = 'Please complete the verification challenge below and try again.';
          msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
      }

      msg.className = 'hidden mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem]';
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.7';
      label.textContent = 'Sending...';

      // No key configured yet → graceful demo mode.
      if (!KEY || KEY === 'your-web3forms-access-key') {
        setTimeout(() => {
          msg.className = 'mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem] success';
          msg.textContent = '✓ Form is valid! Set PUBLIC_WEB3FORMS_KEY to receive real submissions.';
          form.reset();
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          label.textContent = 'Send Request';
        }, 700);
        return;
      }

      try {
        const data = Object.fromEntries(new FormData(form).entries());
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ access_key: KEY, subject: SUBJECT, ...data }),
        });
        const out = await res.json();
        if (out.success) {
          msg.className = 'mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem] success';
          msg.textContent = SUCCESS;
          form.reset();
        } else {
          // Surface the real Web3Forms reason (e.g. captcha/spam) instead of a generic message.
          msg.className = 'mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem] error';
          msg.textContent = out.message || 'Something went wrong. Please try again in a moment.';
        }
      } catch (err) {
        msg.className = 'mb-[18px] rounded-xl px-4 py-3.5 text-[0.9rem] error';
        msg.textContent = 'Network error — please check your connection and try again.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.style.opacity = '1';
        label.textContent = 'Send Request';
        // hCaptcha tokens are single-use — reset so the next submit gets a fresh one.
        if (CAPTCHA && (window as any).hcaptcha) (window as any).hcaptcha.reset();
        msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });
  }
</script>
