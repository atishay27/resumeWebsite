---
import '../styles/global.css';
import resume from '../data/resume.json';
const { meta, profile, socials, experience, education, skills } = resume;

// ---- Person + WebSite structured data (JSON-LD) ----
// Built from resume.json so it stays in sync with the visible content.
const currentRole = experience[0];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${meta.siteUrl}/#person`,
      name: profile.name,
      jobTitle: profile.title,
      description: meta.description,
      url: meta.siteUrl,
      image: `${meta.siteUrl}/og.jpg`,
      sameAs: socials.map((s) => s.url),
      knowsAbout: skills.flatMap((s) => s.items),
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bengaluru',
        addressRegion: 'Karnataka',
        addressCountry: 'IN',
      },
      worksFor: { '@type': 'Organization', name: currentRole.company },
      alumniOf: education.map((e) => ({ '@type': 'CollegeOrUniversity', name: e.university })),
    },
    {
      '@type': 'WebSite',
      '@id': `${meta.siteUrl}/#website`,
      url: meta.siteUrl,
      name: meta.title,
      description: meta.description,
      inLanguage: 'en',
      author: { '@id': `${meta.siteUrl}/#person` },
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="author" content="Atishay Jain" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a1628" />
    <link rel="canonical" href={meta.siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Atishay Jain" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={meta.siteUrl} />
    <meta property="og:image" content={`${meta.siteUrl}/og.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Atishay Jain — Backend Developer" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={`${meta.siteUrl}/og.jpg`} />
    <meta name="twitter:image:alt" content="Atishay Jain — Backend Developer" />

    <!-- Self-hosted fonts: preload the two used above the fold -->
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/sora-variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <slot />

    <script>
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ---------- Reveal on scroll ----------
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal:not(.in)').forEach((el) => io.observe(el));

      // ---------- Animated counters ----------
      const counters = document.querySelectorAll<HTMLElement>('.num[data-target]');
      const cio = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              animate(e.target as HTMLElement);
              cio.unobserve(e.target);
            }
          });
        },
        { threshold: 0.5 }
      );
      counters.forEach((c) => cio.observe(c));

      function animate(el: HTMLElement) {
        const target = parseFloat(el.dataset.target || '0');
        const dec = parseInt(el.dataset.decimals || '0');
        const suf = el.dataset.suffix || '';
        if (reduceMotion) {
          el.textContent = (dec ? target.toFixed(dec) : Math.floor(target).toString()) + suf;
          return;
        }
        const steps = 60;
        const inc = target / steps;
        let cur = 0,
          i = 0;
        const t = setInterval(() => {
          i++;
          cur += inc;
          if (i >= steps) {
            cur = target;
            clearInterval(t);
          }
          el.textContent = (dec ? cur.toFixed(dec) : Math.floor(cur).toString()) + suf;
        }, 18);
      }
    </script>
  </body>
</html>
